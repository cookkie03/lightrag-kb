# ============================================================
# LightRAG-KB — configurazione centrale condivisa
# Modifica questi valori: vengono usati da `ragcli` per generare
# l'.env di ogni knowledge base. Le KB già create NON vengono
# riscritte automaticamente: usa `ragcli regen <name>` (o --regen).
# ============================================================

# --- Provider: ollama | openrouter ---
LLM_PROVIDER=ollama

# --- Ollama ---
OLLAMA_HOST=http://localhost:11434

# --- LLM per estrazione entità/relazioni (configurabile) ---
# ROBUSTEZZA: modello *senza thinking* per definizione. LightRAG (questa versione)
# non può passare a Ollama né `think:false` né `/no_think`, e su Ollama 0.30 il
# thinking non è "cuocibile" in un Modelfile: quindi l'unico modo robusto e portabile
# per non avere ragionamento infinito è usare un modello instruct che non pensa.
# Scelto granite4.1:3b (IBM): instruct/no-think, forte su RAG/estrazione/output
# strutturato, multilingua (ita ok), tag pubblico ri-scaricabile ovunque, ~2GB.
# (qwen3.5:4b-mlx era "thinking" -> estrazione lentissima -> timeout/409.)
# Override per singola KB: campo `llm_model` nel registry.yaml.
# I modelli mancanti vengono scaricati in automatico da `ragcli start` (auto-pull).
# Più qualità (M4/16GB regge): granite4.1:8b.
LLM_MODEL=granite4.1:3b
# CONTESTO — leva critica di velocità per granite: l'architettura ibrida Mamba è
# molto sensibile al num_ctx. Misurato su M4: 8192=~17 tok/s, 16384=~5 tok/s (3x più
# lento!). 8192 basta per chunk da 1200 token + prompt di estrazione + gleaning, e
# tiene la RAM bassa (~2.9GB). NON alzarlo oltre 8192 con modelli ibridi Mamba.
OLLAMA_LLM_NUM_CTX=8192
# Tetto ai token generati per chiamata (l'output di estrazione è breve): margine ampio.
OLLAMA_LLM_NUM_PREDICT=4096

# --- Robustezza pipeline di ingest (leve native LightRAG) ---
# Timeout per singola chiamata LLM (default 180s): un 4B "thinking" locale che
# estrae entità su un chunk può superare i 3 minuti -> alzato a 900s (15 min).
LLM_TIMEOUT=900
# Timeout generale delle operazioni async del server (default 300s).
TIMEOUT=900
# Chiamate LLM in parallelo (default 4): con UN solo modello locale, 4 richieste
# contemporanee si rallentano a vicenda e sforano il timeout. 2 = miglior compromesso.
MAX_ASYNC=2
# Timeout per le chiamate di embedding (default 30s): margine per batch lenti.
EMBEDDING_TIMEOUT=120

# --- Embedding ---
# qwen3-embedding:0.6b = 600M parametri, contesto 32k, dimensione nativa 1024.
# Ottimo bilanciamento qualità/costo su Mac 16GB.
EMBEDDING_MODEL=qwen3-embedding:0.6b
EMBEDDING_DIM=1024
OLLAMA_EMBEDDING_NUM_CTX=8192

# --- OpenRouter (usato se LLM_PROVIDER=openrouter) ---
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_HOST=https://openrouter.ai/api/v1
OPENROUTER_LLM_MODEL=openrouter/owl-alpha
OPENROUTER_EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free
OPENROUTER_EMBEDDING_DIM=2048

# --- OCR (preprocessing PDF/immagini prima dell'embedding) ---
# mineru  = usa il servizio mineru-api su :8000 (acceso col toggle)
# glmocr  = usa glm-ocr via Ollama (tutto locale, nessun servizio)
# docling = usa Docling (IBM), tutto locale, nessun servizio, settato a massima qualità
OCR_BACKEND=docling
MINERU_API=http://127.0.0.1:8000
MINERU_TIMEOUT=3600
# Token per mineru cloud (mineru.net → API service → crea token)
MINERU_CLOUD_API_KEY=your-mineru-cloud-token
GLMOCR_CONFIG=/Users/luca/.claude/skills/glm-ocr/config.yaml
GLMOCR_PYTHON=/Users/luca/.venv/bin/python
# Docling: stesso venv ML condiviso di glm-ocr/mineru. Lingue OCR e timeout.
# OCR engine: ocrmac (Vision framework nativo Apple, Neural Engine) — su M4 ~3x più
# rapido di EasyOCR a parità di qualità testo riconosciuto. Table structure ACCURATE,
# accelerator MPS espliciti per i modelli torch (layout/table). Office (docx/pptx/xlsx)
# e audio/video (Whisper MLX, vedi DOCLING_LANG per la lingua di trascrizione) sono
# SEMPRE instradati a Docling, indipendentemente da OCR_BACKEND: nessun altro backend
# li supporta. Richiede mlx-whisper installato e ffmpeg sul PATH.
DOCLING_PYTHON=/Users/luca/.venv/bin/python
DOCLING_LANG=it,en
DOCLING_TIMEOUT=3600

# --- Rerank (disabilitato: LightRAG non supporta rerank via Ollama) ---
RERANK_BINDING=null

# --- Qualità RAG (leve native LightRAG, nessuna infra extra) ---
# Lingua del knowledge graph: allineala alla lingua dei tuoi documenti.
SUMMARY_LANGUAGE=Italian
# Passaggi extra di estrazione entità/relazioni (più alto = grafo più completo, più LLM in ingest).
# 1 = un passaggio di rifinitura: dimezza il lavoro LLM per chunk (robustezza > recall marginale).
MAX_GLEANING=1
# Sovrapposizione tra chunk: più continuità di contesto.
CHUNK_SIZE=1200
CHUNK_OVERLAP_SIZE=150
# Soglia similarità coseno nel retrieval: più alta = meno rumore (default 0.2).
COSINE_THRESHOLD=0.25

# --- Porta di partenza per le KB (incrementata automaticamente) ---
BASE_PORT=9621
